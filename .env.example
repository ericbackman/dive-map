# Environment variables for the dive-map helper scripts.
# Copy this file to .env and fill in your own values. .env is gitignored.

# Base directory of your local iCloud Photos export that the scripts scan for
# dive videos. Used by scripts/scan_all_icloud.py and
# scripts/classify_dive_videos.py.
#
# If unset, the scripts default to a cross-platform location:
#   scan_all_icloud.py      -> ~/iCloudPhotos
#   classify_dive_videos.py -> ~/iCloudPhotos/Shared
#
# Set this to point at your actual export, for example:
#   macOS/Linux: DIVE_ICLOUD_BASE=/Users/you/Pictures/iCloudPhotos
#   Windows:     DIVE_ICLOUD_BASE=C:\Users\you\iCloudPhotos
DIVE_ICLOUD_BASE=

# Google Gemini API key, required to classify dive video frames.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
